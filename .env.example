# Server
PORT=5000
NODE_ENV=development

# Database (required in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adaudit_pro

# Auth — REQUIRED in production (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis (optional — omit in production unless you add a Redis service)
# Do NOT point at 127.0.0.1 on Railway — use REDIS_URL from Railway Redis plugin
# REDIS_URL=redis://default:password@host:6379

# Google OAuth (required for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Railway (auto-derived from RAILWAY_PUBLIC_DOMAIN if unset):
# GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/auth/google/callback

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MANAGER_ACCOUNT_ID=

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=
ANTHROPIC_API_KEY_4=

# Public app URL (CORS + OAuth)
# Local dev:
CLIENT_URL=http://localhost:5173
# Railway (auto-derived from RAILWAY_PUBLIC_DOMAIN if unset):
# CLIENT_URL=https://your-app.up.railway.app

# Railway auto-set (do not set manually):
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# PORT=8080

# Feature flags
# Local development: USE_MOCK_DATA=true (default when NODE_ENV=development)
# Production (Railway): omit or set USE_MOCK_DATA=false
USE_MOCK_DATA=true

# Puppeteer (set automatically in Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
