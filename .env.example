# Server
PORT=5000
NODE_ENV=development

# Database (optional — mock mode works without DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adaudit_pro

# Auth — REQUIRED in production (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis (optional — falls back to in-memory audit simulation)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_URL=redis://default:password@host:6379

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Railway (replace with your public domain):
# GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/auth/google/callback

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MANAGER_ACCOUNT_ID=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Public app URL (used for CORS + OAuth redirects)
# Local dev:
CLIENT_URL=http://localhost:5173
# Railway (set to your public URL, or rely on RAILWAY_PUBLIC_DOMAIN auto-detection):
# CLIENT_URL=https://your-app.up.railway.app

# Railway auto-set variables (do not set manually unless needed):
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# Feature flags
USE_MOCK_DATA=true

# Puppeteer (set automatically in Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
